{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "lacadev/projects-slider-block",
    "version": "1.0.0",
    "title": "Projects Slider Block",
    "category": "lacadev-blocks",
    "description": "Hiển thị danh sách dự án dạng Swiper slider fullwidth — chọn post type, danh mục, số lượng; hỗ trợ auto/manual.",
    "keywords": [
        "project",
        "slider",
        "swiper",
        "portfolio",
        "du-an"
    ],
    "textdomain": "laca",
    "supports": {
        "html": false,
        "align": [
            "wide",
            "full"
        ]
    },
    "example": {
        "viewportWidth": 800,
        "attributes": {
            "__isPreview": true
        }
    },
    "attributes": {
        "__isPreview": {
            "type": "boolean",
            "default": false
        },
        "sectionBadge": {
            "type": "string",
            "default": "Dự Án Tiêu Biểu"
        },
        "sectionTitle": {
            "type": "string",
            "default": "Dự Án Sử Dụng Sản Phẩm"
        },
        "ctaText": {
            "type": "string",
            "default": "Xem Thêm"
        },
        "headingColor": {
            "type": "string",
            "default": ""
        },
        "postType": {
            "type": "string",
            "default": "post"
        },
        "taxonomy": {
            "type": "string",
            "default": "category"
        },
        "selectedTerms": {
            "type": "array",
            "default": []
        },
        "mode": {
            "type": "string",
            "default": "auto"
        },
        "orderBy": {
            "type": "string",
            "default": "date"
        },
        "order": {
            "type": "string",
            "default": "DESC"
        },
        "postsCount": {
            "type": "number",
            "default": 6
        },
        "selectedPosts": {
            "type": "array",
            "default": []
        },
        "bgColor": {
            "type": "string",
            "default": "#0f0f0f"
        },
        "bgOpacity": {
            "type": "number",
            "default": 100
        },
        "pauseOnHover": {
            "type": "boolean",
            "default": true
        },
        "showPopupForm": {
            "type": "boolean",
            "default": false
        },
        "popupBudgetOptions": {
            "type": "array",
            "default": [
                "Dưới 1 tỷ",
                "1 - 3 tỷ",
                "3 - 5 tỷ",
                "5 - 10 tỷ",
                "Trên 10 tỷ"
            ]
        },
        "popupButtonText": {
            "type": "string",
            "default": "GỬI YÊU CẦU"
        },
        "heading": {
            "type": "string",
            "default": ""
        },
        "subheading": {
            "type": "string",
            "default": ""
        },
        "marginTop": {
            "type": "number",
            "default": 0
        },
        "marginBottom": {
            "type": "number",
            "default": 0
        },
        "paddingTop": {
            "type": "number",
            "default": 60
        },
        "paddingBottom": {
            "type": "number",
            "default": 55
        }
    },
    "editorScript": "block-block-projects-slider-editor",
    "style": "block-block-projects-slider"
}
