{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "lacadev/video-feedback-block",
    "title": "Video Feedback Slider",
    "category": "lacadev-blocks",
    "icon": "video-alt3",
    "editorScript": "block-block-video-feedback-editor",
    "style": "block-block-video-feedback",
    "textdomain": "laca",
    "supports": {
        "html": false,
        "align": [
            "wide",
            "full"
        ]
    },
    "attributes": {
        "heading": {
            "type": "string",
            "default": ""
        },
        "videos": {
            "type": "array",
            "default": []
        },
        "slidesPerView": {
            "type": "number",
            "default": 4
        },
        "spaceBetween": {
            "type": "number",
            "default": 20
        },
        "loop": {
            "type": "boolean",
            "default": true
        },
        "autoplay": {
            "type": "boolean",
            "default": false
        },
        "autoplayDelay": {
            "type": "number",
            "default": 3000
        },
        "showPagination": {
            "type": "boolean",
            "default": true
        },
        "showNavigation": {
            "type": "boolean",
            "default": true
        },
        "bgColor": {
            "type": "string",
            "default": "#0f0f0f"
        },
        "bgOpacity": {
            "type": "number",
            "default": 100
        },
        "__isPreview": {
            "type": "boolean",
            "default": false
        },
        "subheading": {
            "type": "string",
            "default": ""
        },
        "marginTop": {
            "type": "number",
            "default": 0
        },
        "marginBottom": {
            "type": "number",
            "default": 0
        },
        "paddingTop": {
            "type": "number",
            "default": 60
        },
        "paddingBottom": {
            "type": "number",
            "default": 55
        }
    },
    "example": {
        "viewportWidth": 800,
        "attributes": {
            "__isPreview": true
        }
    }
}
