{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "lacadev/team-carousel-block",
    "title": "Team Carousel",
    "category": "lacadev-blocks",
    "icon": "groups",
    "editorScript": "block-block-team-carousel-editor",
    "style": "block-block-team-carousel",
    "textdomain": "laca",
    "supports": {
        "html": false,
        "align": [
            "wide",
            "full"
        ]
    },
    "attributes": {
        "sectionTitle": {
            "type": "string",
            "default": ""
        },
        "slides": {
            "type": "array",
            "default": []
        },
        "loop": {
            "type": "boolean",
            "default": true
        },
        "autoplay": {
            "type": "boolean",
            "default": false
        },
        "autoplayDelay": {
            "type": "number",
            "default": 3000
        },
        "spaceBetween": {
            "type": "number",
            "default": 24
        },
        "inactiveScale": {
            "type": "number",
            "default": 60
        },
        "bgColor": {
            "type": "string",
            "default": "#ffffff"
        },
        "bgOpacity": {
            "type": "number",
            "default": 100
        },
        "__isPreview": {
            "type": "boolean",
            "default": false
        },
        "heading": {
            "type": "string",
            "default": ""
        },
        "subheading": {
            "type": "string",
            "default": ""
        },
        "marginTop": {
            "type": "number",
            "default": 0
        },
        "marginBottom": {
            "type": "number",
            "default": 0
        },
        "paddingTop": {
            "type": "number",
            "default": 60
        },
        "paddingBottom": {
            "type": "number",
            "default": 55
        }
    },
    "example": {
        "viewportWidth": 800,
        "attributes": {
            "__isPreview": true
        }
    }
}
