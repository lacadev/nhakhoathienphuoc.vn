{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "lacadev/shortcode-widget-block",
    "title": "Shortcode Widget",
    "category": "lacadev-blocks",
    "icon": "shortcode",
    "editorScript": "block-block-shortcode-widget-editor",
    "style": "block-block-shortcode-widget",
    "textdomain": "laca",
    "supports": {
        "html": false
    },
    "attributes": {
        "heading": {
            "type": "string",
            "default": ""
        },
        "shortcode1": {
            "type": "string",
            "default": ""
        },
        "shortcode2": {
            "type": "string",
            "default": ""
        },
        "bgColor": {
            "type": "string",
            "default": "#0f0f0f"
        },
        "bgOpacity": {
            "type": "number",
            "default": 100
        },
        "__isPreview": {
            "type": "boolean",
            "default": false
        },
        "subheading": {
            "type": "string",
            "default": ""
        },
        "marginTop": {
            "type": "number",
            "default": 0
        },
        "marginBottom": {
            "type": "number",
            "default": 0
        },
        "paddingTop": {
            "type": "number",
            "default": 60
        },
        "paddingBottom": {
            "type": "number",
            "default": 55
        }
    },
    "example": {
        "viewportWidth": 800,
        "attributes": {
            "__isPreview": true
        }
    }
}
