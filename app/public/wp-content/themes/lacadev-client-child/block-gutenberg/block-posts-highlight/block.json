{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "lacadev/posts-highlight-block",
    "title": "Posts Highlight Block",
    "category": "lacadev-blocks",
    "icon": "layout",
    "editorScript": "block-block-posts-highlight-editor",
    "style": "block-block-posts-highlight",
    "textdomain": "laca",
    "supports": {
        "html": false,
        "align": [
            "wide",
            "full"
        ]
    },
    "attributes": {
        "sectionTitle": {
            "type": "string",
            "default": "Tin Mới Nhất"
        },
        "ctaText": {
            "type": "string",
            "default": "Xem Chi Tiết"
        },
        "postType": {
            "type": "string",
            "default": "post"
        },
        "taxonomy": {
            "type": "string",
            "default": ""
        },
        "selectedTerms": {
            "type": "array",
            "default": []
        },
        "mode": {
            "type": "string",
            "default": "auto"
        },
        "orderBy": {
            "type": "string",
            "default": "date"
        },
        "order": {
            "type": "string",
            "default": "DESC"
        },
        "postsCount": {
            "type": "number",
            "default": 5
        },
        "selectedPosts": {
            "type": "array",
            "default": []
        },
        "bgColor": {
            "type": "string",
            "default": "#0f0f0f"
        },
        "bgOpacity": {
            "type": "number",
            "default": 100
        },
        "__isPreview": {
            "type": "boolean",
            "default": false
        },
        "heading": {
            "type": "string",
            "default": ""
        },
        "subheading": {
            "type": "string",
            "default": ""
        },
        "marginTop": {
            "type": "number",
            "default": 0
        },
        "marginBottom": {
            "type": "number",
            "default": 0
        },
        "paddingTop": {
            "type": "number",
            "default": 60
        },
        "paddingBottom": {
            "type": "number",
            "default": 55
        }
    },
    "example": {
        "viewportWidth": 800,
        "attributes": {
            "__isPreview": true
        }
    }
}
